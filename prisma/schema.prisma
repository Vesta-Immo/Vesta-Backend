generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PropertyListState {
  id                String             @id
  financingSettings Json?
  lastSimulation    Json?
  properties        PropertyListItem[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PropertyListItem {
  id                    String                       @id
  stateId               String
  state                 PropertyListState            @relation(fields: [stateId], references: [id], onDelete: Cascade)
  status                PropertyTrackingStatus
  propertyType          PersistedPropertyType
  listingUrl            String?
  departmentCode        String?
  price                 Float
  addressOrSector       String
  propertyTaxAnnual     Float
  coOwnershipFeesAnnual Float
  renovationWorkItems   PropertyRenovationWorkItem[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
}

model PropertyRenovationWorkItem {
  id         String           @id @default(cuid())
  propertyId String
  property   PropertyListItem @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  position   Int
  name       String
  details    String?
  cost       Float
}

enum PropertyTrackingStatus {
  WANTED
  VISITED
}

enum PersistedPropertyType {
  NEW
  OLD
}