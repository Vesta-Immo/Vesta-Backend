generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  supabaseAuthUserId String             @unique
  propertyListState  PropertyListState?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model PropertyListState {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  financingSettings Json?
  lastSimulation    Json?
  properties        PropertyListItem[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PropertyListItem {
  id                    String                       @id
  stateId               String
  state                 PropertyListState            @relation(fields: [stateId], references: [id], onDelete: Cascade)
  status                PropertyTrackingStatus
  propertyType          PersistedPropertyType
  listingUrl            String?
  departmentCode        String?
  price                 Float
  addressOrSector       String
  propertyTaxAnnual     Float
  coOwnershipFeesAnnual Float
  renovationWorkItems   PropertyRenovationWorkItem[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
}

model PropertyRenovationWorkItem {
  id         String           @id @default(cuid())
  propertyId String
  property   PropertyListItem @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  position   Int
  name       String
  details    String?
  cost       Float
}

enum PropertyTrackingStatus {
  WANTED
  VISITED
}

enum PersistedPropertyType {
  NEW
  OLD
}